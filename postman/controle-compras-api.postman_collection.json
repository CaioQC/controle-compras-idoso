    {
      "name": "Teste 2 - User Login (POST /login)",
      "item": [
        {
          "name": "TC2.1 - Login com credenciais válidas",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@familia.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["login"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code é 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contém token JWT', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('access_token');",
                  "});",
                  "",
                  "pm.test('Token é uma string válida', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.access_token).to.be.a('string');",
                  "    pm.expect(jsonData.access_token.length).to.be.greaterThan(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC2.2 - Login com senha incorreta",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
