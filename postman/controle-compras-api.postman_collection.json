{
  "info": {
    "_postman_id": "controle-compras-api",
    "name": "Controle Compras API Tests",
    "description": "Testes de API para o sistema de controle de compras para idosos",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Teste 1 - User Registration (POST /usuario)",
      "item": [
        {
          "name": "TC1.1 - Registro com dados válidos",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João Silva\",\n  \"email\": \"joao.silva@email.com\",\n  \"senha\": \"Senha123@\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/usuario",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["usuario"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code é 201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contém id do usuário', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "});",
                  "",
                  "pm.test('Response contém email correto', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.email).to.equal('joao.silva@email.com');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC1.2 - Registro com email duplicado",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Maria Santos\",\n  \"email\": \"joao.silva@email.com\",\n  \"senha\": \"Senha456@\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/usuario",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["usuario"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code é 400 (Bad Request)', function() {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Response contém mensagem de erro', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('email');",
                  "});"
                ]
              }
            }
          ]
        },
        {
